{
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cspell/dict-en-au": "^1.1.23",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "cspell": "^9.8.0",
    "happy-dom": "^20.10.6",
    "html-validate": "^10.17.0",
    "markdownlint-cli": "^0.46.0",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "node --run vitest run --coverage",
    "coverage": "node --run vitest run --coverage",
    "check": "biome check",
    "lint": "biome lint .",
    "spell": "bunx cspell '**/*.{py,js,css,html,md,json,Dockerfile}'",
    "check_markdown": "bunx markdownlint --ignore node_modules --fix ./**/*.md",
    "format": "biome format --write ."
  }
}
